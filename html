<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Win Big — Zamp Giveaway</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:        #fafaf8;
    --bg-card:   #f4f3f0;
    --ink:       #111111;
    --ink-mid:   #555555;
    --ink-light: #999999;
    --border:    #e2e0db;
    --rule:      #dddbd6;
    --yellow-bg: #fefce8;
    --yellow-bd: #fde68a;
    --yellow-tx: #92400e;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    background: var(--bg);
    color: var(--ink);
    overflow-x: hidden;
    font-size: 16px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }

  /* ── STICKY BAR ── */
  .sticky-bar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    background: var(--ink);
    color: #fff;
    font-size: 13px;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 10px 20px;
    text-align: center;
  }
  .sticky-bar a {
    color: #fff;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.45);
    padding-bottom: 1px;
    font-weight: 600;
    transition: border-color 0.2s;
    white-space: nowrap;
  }
  .sticky-bar a:hover { border-color: #fff; }

  /* ── NAV ── */
  .nav-wrap {
    margin-top: 42px;
    border-bottom: 1px solid var(--border);
  }
  nav {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 32px;
  }
  .nav-logo {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 22px;
    font-weight: 400;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .nav-cta {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    border: 1px solid var(--border);
    padding: 8px 20px;
    border-radius: 4px;
    transition: border-color 0.2s, background 0.2s;
  }
  .nav-cta:hover { border-color: var(--ink); background: var(--bg-card); }

  /* ── HERO ── */
  .hero {
    max-width: 820px;
    margin: 0 auto;
    padding: 96px 32px 76px;
    text-align: center;
  }
  .hero-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--ink-light);
    margin-bottom: 26px;
    padding: 5px 14px;
    border: 1px solid var(--border);
    border-radius: 100px;
  }
  .hero h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(46px, 7.5vw, 84px);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 22px;
  }
  .hero h1 em { font-style: italic; font-weight: 400; }
  .hero-sub {
    font-size: 17px;
    color: var(--ink-mid);
    max-width: 500px;
    margin: 0 auto 42px;
    line-height: 1.65;
    font-weight: 400;
  }
  .hero-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--ink);
    color: #fff;
    font-weight: 600;
    font-size: 14.5px;
    padding: 13px 26px;
    border-radius: 5px;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    letter-spacing: 0.005em;
  }
  .btn-primary:hover { background: #2a2a2a; transform: translateY(-1px); }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    color: var(--ink);
    font-weight: 500;
    font-size: 14.5px;
    padding: 13px 26px;
    border-radius: 5px;
    text-decoration: none;
    border: 1px solid var(--border);
    transition: border-color 0.2s, transform 0.15s;
  }
  .btn-ghost:hover { border-color: var(--ink); transform: translateY(-1px); }
  .hero-meta {
    margin-top: 22px;
    font-size: 12.5px;
    color: var(--ink-light);
  }
  .hero-meta strong { color: var(--ink-mid); font-weight: 500; }

  /* ── COUNTDOWN ── */
  .countdown-outer {
    max-width: 440px;
    margin: 40px auto 0;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 7px;
    overflow: hidden;
    display: flex;
  }
  .cd-unit {
    flex: 1;
    padding: 16px 10px;
    text-align: center;
    border-right: 1px solid var(--border);
  }
  .cd-unit:last-child { border-right: none; }
  .cd-num {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .cd-label {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-light);
    margin-top: 4px;
    font-weight: 500;
  }

  /* ── SHARED ── */
  hr {
    border: none;
    border-top: 1px solid var(--rule);
    max-width: 1100px;
    margin: 0 auto;
  }
  section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 84px 32px;
  }
  .section-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--ink-light);
    margin-bottom: 12px;
  }
  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(30px, 4vw, 46px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 14px;
  }
  .section-title em { font-style: italic; font-weight: 400; }
  .section-sub {
    font-size: 16px;
    color: var(--ink-mid);
    max-width: 460px;
    line-height: 1.65;
  }

  /* ── VALUE PROPS ── */
  .value-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: start;
  }
  .value-cards { display: flex; flex-direction: column; }
  .value-card {
    padding: 22px 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }
  .value-card:first-child { border-top: 1px solid var(--border); }
  .value-icon { font-size: 20px; flex-shrink: 0; width: 36px; margin-top: 1px; text-align: center; }
  .value-card h3 { font-size: 15px; font-weight: 600; color: var(--ink); margin-bottom: 3px; }
  .value-card p { font-size: 13.5px; color: var(--ink-mid); line-height: 1.6; }

  /* ── STEPS ── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    margin-top: 52px;
    border: 1px solid var(--border);
    border-radius: 7px;
    overflow: hidden;
  }
  .step { background: var(--bg); padding: 38px 30px; }
  .step-num {
    font-family: 'Playfair Display', serif;
    font-size: 44px;
    font-weight: 700;
    color: var(--rule);
    line-height: 1;
    margin-bottom: 18px;
  }
  .step h3 { font-size: 15px; font-weight: 600; color: var(--ink); margin-bottom: 7px; line-height: 1.35; }
  .step p { font-size: 13.5px; color: var(--ink-mid); line-height: 1.6; }
  .steps-cta { text-align: center; margin-top: 34px; }

  /* ── PRIZES ── */
  .prizes-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 36px;
  }
  .prizes-note { font-size: 13px; color: var(--ink-light); font-style: italic; }

  .prizes-grid {
    display: grid;
    grid-template-columns: 1.45fr 1fr;
    gap: 16px;
    align-items: start;
  }
  .prize-card {
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 34px 28px;
    background: var(--bg);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .prize-card:hover {
    border-color: #bbb;
    box-shadow: 0 3px 20px rgba(0,0,0,0.05);
  }
  .prize-card.featured {
    background: var(--ink);
    border-color: var(--ink);
    color: #fff;
  }
  .prize-card.featured:hover { box-shadow: 0 6px 28px rgba(0,0,0,0.16); }
  .prize-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 100px;
    margin-bottom: 18px;
  }
  .prize-badge.dark  { background: rgba(255,255,255,0.1);  color: rgba(255,255,255,0.65); border: 1px solid rgba(255,255,255,0.15); }
  .prize-badge.light { background: var(--bg-card); color: var(--ink-mid); border: 1px solid var(--border); }
  .prize-emoji { font-size: 42px; display: block; margin-bottom: 14px; line-height: 1; }
  .prize-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 7px;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .prize-card.featured h3 { color: #fff; }
  .prize-card:not(.featured) h3 { color: var(--ink); }
  .prize-card.featured p { font-size: 13.5px; color: rgba(255,255,255,0.55); line-height: 1.55; }
  .prize-card:not(.featured) p { font-size: 13.5px; color: var(--ink-mid); line-height: 1.55; }

  /* runner-up stack */
  .runners-stack { display: flex; flex-direction: column; gap: 0; }
  .or-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-light);
    padding: 10px 0;
  }
  .or-divider::before, .or-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }
  .runner-card {
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 24px 24px;
    background: var(--bg);
    display: flex;
    align-items: center;
    gap: 18px;
    transition: border-color 0.2s;
  }
  .runner-card:hover { border-color: #bbb; }
  .runner-emoji { font-size: 34px; flex-shrink: 0; }
  .runner-card h3 { font-size: 16px; font-weight: 600; color: var(--ink); margin-bottom: 3px; }
  .runner-card p { font-size: 13px; color: var(--ink-mid); }

  /* ── FORM ── */
  .form-outer { max-width: 660px; margin: 0 auto; }
  .form-box {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 52px;
    margin-top: 44px;
  }
  .form-box h2 {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 6px;
    color: var(--ink);
  }
  .form-warning {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    background: var(--yellow-bg);
    border: 1px solid var(--yellow-bd);
    border-radius: 5px;
    padding: 11px 15px;
    font-size: 13px;
    color: var(--yellow-tx);
    margin: 18px 0 28px;
    line-height: 1.5;
  }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .form-group { margin-bottom: 16px; }
  .form-group label {
    display: block;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-mid);
    margin-bottom: 6px;
  }
  .form-group input,
  .form-group select {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 10px 13px;
    color: var(--ink);
    font-family: 'Inter', sans-serif;
    font-size: 14.5px;
    outline: none;
    transition: border-color 0.2s;
    -webkit-appearance: none;
  }
  .form-group input:focus,
  .form-group select:focus { border-color: var(--ink); }
  .form-group input::placeholder { color: var(--ink-light); }
  .form-group select option { background: #fff; }
  .form-check {
    display: flex;
    align-items: flex-start;
    gap: 11px;
    margin: 18px 0 26px;
  }
  .form-check input[type="checkbox"] {
    width: 15px; height: 15px; min-width: 15px;
    accent-color: var(--ink);
    margin-top: 3px;
    cursor: pointer;
  }
  .form-check span { font-size: 13px; color: var(--ink-mid); line-height: 1.55; }
  .btn-submit {
    display: block;
    width: 100%;
    background: var(--ink);
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 15px;
    padding: 14px;
    border-radius: 5px;
    border: none;
    cursor: pointer;
    letter-spacing: 0.01em;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-submit:hover { background: #2a2a2a; transform: translateY(-1px); }

  /* ── TRUST ── */
  .trust-strip {
    background: var(--bg-card);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .trust-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 26px 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 20px 36px;
    align-items: center;
    justify-content: center;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    color: var(--ink-light);
  }
  .trust-item::before {
    content: '';
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--border);
    flex-shrink: 0;
  }

  /* ── FINAL CTA ── */
  .final-cta {
    text-align: center;
    padding: 108px 32px;
    max-width: 660px;
    margin: 0 auto;
  }
  .final-cta h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(34px, 5vw, 54px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.08;
    color: var(--ink);
    margin-bottom: 12px;
  }
  .final-cta h2 em { font-style: italic; font-weight: 400; }
  .final-cta p { font-size: 16px; color: var(--ink-mid); margin-bottom: 34px; }

  /* ── FOOTER ── */
  footer {
    border-top: 1px solid var(--border);
    padding: 28px 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    max-width: 1100px;
    margin: 0 auto;
    font-size: 12px;
    color: var(--ink-light);
  }
  .footer-logo {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    font-weight: 400;
    color: var(--ink);
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .hero > * { animation: fadeUp 0.5s ease both; }
  .hero-eyebrow   { animation-delay: 0.04s; }
  .hero h1        { animation-delay: 0.11s; }
  .hero-sub       { animation-delay: 0.18s; }
  .hero-btns      { animation-delay: 0.25s; }
  .hero-meta      { animation-delay: 0.31s; }
  .countdown-outer{ animation-delay: 0.37s; }

  /* ── RESPONSIVE ── */
  @media (max-width: 800px) {
    nav { padding: 16px 20px; }
    .hero { padding: 60px 20px 56px; }
    .value-layout { grid-template-columns: 1fr; gap: 40px; }
    .steps-grid { grid-template-columns: 1fr; }
    .prizes-grid { grid-template-columns: 1fr; }
    .form-box { padding: 28px 20px; }
    .form-row { grid-template-columns: 1fr; }
    footer { flex-direction: column; text-align: center; }
  }
</style>
</head>
