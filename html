        ⚠️&nbsp; You must submit this form <em>after</em> leaving your review to be officially entered.
      </div>

      <form onsubmit="handleSubmit(event)">
        <div class="form-row">
          <div class="form-group">
            <label>Email Address *</label>
            <input type="email" placeholder="you@yourstore.com" required>
          </div>
          <div class="form-group">
            <label>Shopify Store URL *</label>
            <input type="text" placeholder="yourstore.myshopify.com" required>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Installed the app? *</label>
            <select required>
              <option value="" disabled selected>Select one</option>
              <option value="yes">Yes ✓</option>
              <option value="no">Not yet</option>
            </select>
          </div>
          <div class="form-group">
            <label>Left a review? *</label>
            <select required>
              <option value="" disabled selected>Select one</option>
              <option value="yes">Yes ✓</option>
              <option value="no">Not yet</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>Review link or screenshot (optional)</label>
          <input type="text" placeholder="Paste a link to your review">
        </div>
        <label class="form-check">
          <input type="checkbox" required>
          <span>I have installed the app and left an honest review. I understand winners are selected at random and agree to be contacted via email.</span>
        </label>
        <button type="submit" class="btn-submit">Enter Giveaway →</button>
      </form>
    </div>
  </div>
</section>

